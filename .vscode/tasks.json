 {
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build Game",
      "type": "shell",
      "command": "g++",
      "args": [
        "src/main.cpp",
        "-o", "game.exe",
        "-IC:/SDL2/SDL2-2.30.6/include",
        "-LC:/SDL2/SDL2-2.30.6/lib",
        "-lmingw32",
        "-lSDL2main",
        "-lSDL2",
        "-Wall"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$gcc"]
    }
  ]
}